# Copy to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://boop:yourpassword@localhost:5432/boopfish

# ── Site ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
SITE_URL=https://boop.fish        # used to build password reset links

# ── Bootstrap admin account ───────────────────────────────────────────────────
# Created on first server startup if the username doesn't already exist.
# Change these before deploying. Leave blank to skip bootstrap.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# 1. Go to discord.com/developers/applications and create an app
# 2. Under OAuth2 → copy Client ID and Client Secret
# 3. Add redirect URI: https://boop.fish/auth/discord/callback
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_GUILD_ID=your_server_id_here
DISCORD_BOT_TOKEN=your_bot_token_here   # used by the site server to call Discord REST + authenticate bot API requests

# ── Email: choose one provider ────────────────────────────────────────────────
EMAIL_PROVIDER=resend             # "resend" (default) or "smtp"
EMAIL_FROM=noreply@boop.fish      # sender address shown in emails

# Option A — Resend (recommended, free up to 3k emails/month)
# 1. Sign up at resend.com
# 2. Add domain boop.fish → they give you 2 DNS records to add (SPF + DKIM)
# 3. Create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
